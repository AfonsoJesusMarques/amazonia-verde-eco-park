<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main class="page-content">
    <h1>Wildlife Search</h1>

    <p>
        Search for Brazilian-inspired habitats, animals and experiences from the park database.
    </p>

    <div  class="search-box">
        <label for="searchInput">Search the park</label>
        <input 
            type="text" 
            id="searchInput" 
            name="searchInput" 
            placeholder="Try jaguar, macaw, pantanal or river"
        >
    </div >

    <div  id="searchResults" class="search-results">
        <p>Start typing to search the database.</p>
    </div >
</main>

<script src="/js/search.js"></script>

